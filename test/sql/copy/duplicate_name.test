# name: test/sql/copy/duplicate_name.test
# group: [copy]

require avro

statement ok
COPY (
	select {
		'a': {
			'child': 21
		},
		'b': {
			'child': true
		}
	} my_struct
) TO '{TEST_DIR}/tmp.avro';

query I
select * from read_avro('{TEST_DIR}/tmp.avro');
----
{'a': {'child': 21}, 'b': {'child': true}}

statement ok
COPY (
	select {
		'a': {
			'field': true
		}
	} structure
) TO '{TEST_DIR}/tmp2.avro' ( ROOT_NAME 'root_a');

query I
select * from read_avro('{TEST_DIR}/tmp2.avro');
----
{'a': {'field': true}}
